# Readback reads API keys from the control panel (no file needed). This file is
# an OPTIONAL fallback if you'd rather use environment variables.

# Inworld: the SAME base64 string you'd paste into the panel.
# Get one at https://platform.inworld.ai
INWORLD_API_KEY=

# ElevenLabs: a plain API key from https://elevenlabs.io (Profile → API Keys)
ELEVENLABS_API_KEY=

# --- Optional overrides (defaults shown) ---
# READBACK_PROVIDER=inworld
# READBACK_PORT=7717
# READBACK_MAX_CHARS=1800
